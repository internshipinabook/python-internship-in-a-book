    "# :,.2f   comma AND 2 decimal places\n",
    "print(f\"Average: N{avg_item:,.2f}\")    # N1,132.18\n",
    "\n",
    "# :.1%    convert decimal to percentage, 1 decimal place\n",
    "print(f\"Margin: {margin:.1%}\")         # 84.8%\n",
    "\n",
    "# :.0%    percentage, no decimal places\n",
    "print(f\"Margin: {margin:.0%}\")         # 85%"
