   "source": [
    "### Exercise 1.9 — Variable update chain"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "88c07b3f",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Start with this:\n",
    "daily_target = 90000\n",
